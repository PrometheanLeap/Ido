# ── Ido Cloud Run Deploy Config ──────────────────────────────
# Copy this file to deploy.env and fill in your values, then run:
#   bash scripts/deploy.sh
#
# deploy.env is gitignored — never commit real secrets.

# ── GCP target ───────────────────────────────────────────────
PROJECT=my-gcp-project
REGION=us-west1
SERVICE_NAME=ido

# ── Deployment mode ──────────────────────────────────────────
# dev | personal | saas | corporate
IDO_MODE=saas

# ── Database (PostgreSQL / Cloud SQL) ────────────────────────
# Private IP (same VPC / same project): host is the instance private IP.
DATABASE_URL=postgresql://ido:password@10.0.0.2:5432/ido

# ── Public URL & CORS ────────────────────────────────────────
# Your custom domain (or the run.app URL). Used for OIDC callbacks.
PUBLIC_URL=https://ido.example.com
CORS_ORIGIN=https://ido.example.com

# ── Secrets ──────────────────────────────────────────────────
# Generate JWT secret: openssl rand -hex 32
# Leave blank to auto-generate on each deploy (sessions reset each deploy).
JWT_SECRET=
IDO_LICENSE_KEY=

# ── OIDC (saas / corporate modes) ────────────────────────────
OIDC_GOOGLE_CLIENT_ID=
OIDC_GOOGLE_CLIENT_SECRET=
OIDC_MICROSOFT_CLIENT_ID=
OIDC_MICROSOFT_CLIENT_SECRET=
OIDC_MICROSOFT_TENANT=

# ── Scaling ──────────────────────────────────────────────────
MIN_INSTANCES=1
MAX_INSTANCES=10
MEMORY=512Mi
CPU=1

# ── Networking (optional) ────────────────────────────────────
# Only needed to reach a private-IP database in a DIFFERENT project,
# or when the DB is not reachable via the default network.
# VPC_CONNECTOR=my-connector
# VPC_EGRESS=private-ranges-only
# CLOUD_SQL_INSTANCE=project:region:instance
