# ── Ido Configuration ────────────────────────────────────────
# Copy this file to .env and adjust values.
# docker compose will load .env automatically.

# ── Mode ────────────────────────────────────────────────────
# dev       — auto-login, dev token, local testing only
# personal  — password auth, single-user per tenant
# saas      — OIDC only, single-user per tenant, license required
# corporate — OIDC only, multi-user shared org, license required
IDO_MODE=personal

# ── Organization (corporate mode only) ──────────────────────
# Short slug identifying this org. All users share one tenant.
# IDO_ORG_SLUG=acme-corp

# ── Admin Users (corporate mode) ────────────────────────────
# Comma-separated emails. First login match gets admin role.
# IDO_ADMIN_EMAILS=admin@company.com,founder@company.com

# ── Corporate User Scoping (corporate mode) ─────────────────
# Allow surfaces for recipients who haven't logged in yet.
# false (default) = reject unless the user has previously authenticated via OIDC.
# true = accept surfaces for any user_id (surface waits for them to log in).
# IDO_CORP_ALLOW_UNKNOWN_USERS=false

# Restrict recipients to specific email domains (comma-separated).
# Empty = allow all domains.
# IDO_CORP_ALLOWED_DOMAINS=company.com,subsidiary.com

# ── Server ──────────────────────────────────────────────────
PORT=8645
HOST=0.0.0.0

# ── Database ─────────────────────────────────────────────────
# SQLite (default, zero-config):
SQLITE_PATH=./data/ido.db

# PostgreSQL (optional — uncomment and set DATABASE_URL):
# DATABASE_URL=postgresql://user:password@host:5432/idodb
# PG_POOL_MAX=5
# PG_IDLE_TIMEOUT=10000

# ── Auth ────────────────────────────────────────────────────
# Change this! Generate: openssl rand -hex 32
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Dev token — only used when IDO_MODE=dev
# IDO_DEV_TOKEN=ido-dev-token

# ── Public URL ───────────────────────────────────────────────
# Override the public-facing URL for callbacks, web push, and
# skills guide links. Auto-detected from request headers when unset.
# Required if running behind a reverse proxy (nginx, Cloudflare, etc.).
# PUBLIC_URL=https://ido.example.com

# ── OIDC (corporate mode) ───────────────────────────────────
# Enable one or both providers. Redirect URI: {PUBLIC_URL}/api/v1/oidc/callback
# Google Cloud Console: https://console.cloud.google.com/apis/credentials
# OIDC_GOOGLE_CLIENT_ID=
# OIDC_GOOGLE_CLIENT_SECRET=

# Azure AD / Entra ID: https://portal.azure.com → App registrations
# OIDC_MICROSOFT_CLIENT_ID=
# OIDC_MICROSOFT_CLIENT_SECRET=
# OIDC_MICROSOFT_TENANT=common   # or your tenant ID for single-org

# ── Web Push (VAPID) ────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
# VAPID_SUBJECT=mailto:admin@example.com
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# ── CORS ────────────────────────────────────────────────────
# CORS_ORIGIN=http://localhost:5173

# ── Licensing (saas + corporate only) ───────────────────────
# IDO_LICENSE_KEY=

# ── Rate Limiting ───────────────────────────────────────────
# RATE_LIMIT_SURFACE_CREATES=60
# RATE_LIMIT_READS=600

# ── Callbacks ───────────────────────────────────────────────
# CALLBACK_MAX_RETRIES=12

# ── Expiry Sweep ────────────────────────────────────────────
# EXPIRY_SWEEP_MS=3600000

# ── SSE ─────────────────────────────────────────────────────
# SSE_KEEPALIVE_MS=30000
